# Copy to `website/.env.local` for Next.js, or `.env` (repo root) for Python scripts.
# Never commit real secrets; keep `.env` and `website/.env.local` out of version control.

# --- OpenAI (embeddings + /api/explore) ---
# scripts/generate_embeddings.py
# website/src/app/api/explore/route.ts
OPENAI_API_KEY=your_openai_api_key

# --- Anthropic (Claude, /api/explore) ---
# website/src/app/api/explore/route.ts
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Upstash Redis (optional, caches /api/explore responses) ---
# website/src/app/api/explore/route.ts
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# --- PaddleOCR Cloud (ocr_cloud.py) ---
PADDLEOCR_TOKEN=your_paddleocr_token

# --- AWS S3 (scripts/upload_pdfs_to_s3.py) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-2
S3_BUCKET_NAME=your_s3_bucket_name

# --- PDF viewer (website/src/app/view/[page]/page.tsx) ---
PDF_BUCKET_URL=https://your_s3_bucket_name.s3.us-east-2.amazonaws.com
